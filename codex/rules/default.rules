prefix_rule(pattern=["git", "add", "."], decision="forbidden", justification="Stage files explicitly instead of using broad staging.")
prefix_rule(pattern=["git", "add", "-A"], decision="forbidden", justification="Stage files explicitly instead of using broad staging.")
prefix_rule(pattern=["git", "add", "--all"], decision="forbidden", justification="Stage files explicitly instead of using broad staging.")
prefix_rule(pattern=["gh", "pr", "checks"], decision="allow")
prefix_rule(pattern=["gh", "pr", "list"], decision="allow")
prefix_rule(pattern=["gh", "pr", "view"], decision="allow")
prefix_rule(pattern=["gh", "pr", "diff"], decision="allow")
prefix_rule(pattern=["gh", "repo", "view"], decision="allow")
prefix_rule(pattern=["gh", "run", "list"], decision="allow")
prefix_rule(pattern=["gh", "run", "view"], decision="allow")
